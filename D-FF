module tbdff();

reg D;

reg clk;

reg reset;

wire Q;

dff dut(D,clk,reset,Q);

initial begin

clk=0;

forever #18 clk=~clk;

end

initial begin

reset=0;

D<=0;

#100;

reset=0;

D<=1;

#100;

D<=0;

#100;

D<=1;

$finish;

end

